# Copy this file to .env.dev or .env.prod outside Git and fill in real values.
# Never commit live credentials.

ENV=dev
APP_ENV=dev

# Database container variables
POSTGRES_DB=bcsentinel
POSTGRES_USER=bcsentinel
POSTGRES_PASSWORD=replace_with_strong_database_password

# SQLAlchemy / psycopg connection string used by the backend
DATABASE_URL=postgresql+psycopg://bcsentinel:replace_with_strong_database_password@postgres:5432/bcsentinel

# Core security
SECRET_KEY=replace_with_a_long_random_secret_key_min_32_chars
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace_with_strong_admin_password_min_16_chars
TOKEN_EXPIRE_MINUTES=60
APP_BASE_URL=http://localhost:3000

# Partner portal / reset mails
PARTNER_RESET_URL_BASE=https://example.com

# SMTP for partner mails
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=mailer@example.com
SMTP_PASSWORD=replace_with_smtp_password
SMTP_USE_TLS=true
SMTP_FROM_EMAIL=noreply@example.com
SMTP_FROM_NAME=BCSentinel

# Stripe billing
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_PREMIUM=
STRIPE_PRICE_ID_PREMIUM_YEARLY=
STRIPE_PRICE_ID_PREMIUM_BASE_MONTHLY=
STRIPE_PRICE_ID_PREMIUM_BASE_YEARLY=
STRIPE_PRICE_ID_PREMIUM_PACK_MONTHLY=
STRIPE_PRICE_ID_PREMIUM_PACK_YEARLY=
# Optional explicit overrides. If unset, the backend derives these from APP_BASE_URL.
# In production, set APP_BASE_URL or all three explicit billing URLs.
BILLING_SUCCESS_URL=
BILLING_CANCEL_URL=
BILLING_PORTAL_RETURN_URL=
